{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://gitmap.dev/schemas/export.schema.json",
  "title": "gitmap export",
  "description": "Machine-readable shape emitted by `gitmap export <out.json>`. Top-level is a single object whose key order is contractual: version, exportedAt, repos, groups, releases, history, bookmarks. The five nested arrays are always present (`[]` when empty, never `null`) so consumers can rely on `jq '.repos | length'` style probes. Per-record property sets are pinned in v2 (v5.82.0+); per-record key ORDER within each nested array follows Go struct field declaration order and is deterministic in practice.",
  "type": "object",
  "required": ["version", "exportedAt", "repos", "groups", "releases", "history", "bookmarks"],
  "additionalProperties": false,
  "properties": {
    "version": {"type": "string", "description": "Schema/export version string."},
    "exportedAt": {"type": "string", "description": "ISO-8601 timestamp when the export was produced."},
    "repos": {
      "type": "array",
      "description": "Scanned repository records (`model.ScanRecord`).",
      "items": {
        "type": "object",
        "required": ["id", "slug", "repoId", "repoName", "httpsUrl", "sshUrl", "discoveredUrl", "branch", "branchSource", "relativePath", "absolutePath", "cloneInstruction", "notes", "depth", "transport"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "integer"},
          "slug": {"type": "string"},
          "repoId": {"type": "string"},
          "repoName": {"type": "string"},
          "httpsUrl": {"type": "string"},
          "sshUrl": {"type": "string"},
          "discoveredUrl": {"type": "string"},
          "branch": {"type": "string"},
          "branchSource": {"type": "string"},
          "relativePath": {"type": "string"},
          "absolutePath": {"type": "string"},
          "cloneInstruction": {"type": "string"},
          "notes": {"type": "string"},
          "depth": {"type": "integer"},
          "transport": {"type": "string"}
        }
      }
    },
    "groups": {
      "type": "array",
      "description": "Group records with member repo slugs (`model.GroupExport` = embedded `Group` + `repoSlugs`).",
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "color", "createdAt", "repoSlugs"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "integer"},
          "name": {"type": "string"},
          "description": {"type": "string"},
          "color": {"type": "string"},
          "createdAt": {"type": "string"},
          "repoSlugs": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "releases": {
      "type": "array",
      "description": "Release records (`model.ReleaseRecord`).",
      "items": {
        "type": "object",
        "required": ["id", "repoId", "version", "tag", "branch", "sourceBranch", "commitSha", "changelog", "notes", "isDraft", "isPreRelease", "isLatest", "source", "createdAt"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "integer"},
          "repoId": {"type": "integer"},
          "version": {"type": "string"},
          "tag": {"type": "string"},
          "branch": {"type": "string"},
          "sourceBranch": {"type": "string"},
          "commitSha": {"type": "string"},
          "changelog": {"type": "string"},
          "notes": {"type": "string"},
          "isDraft": {"type": "boolean"},
          "isPreRelease": {"type": "boolean"},
          "isLatest": {"type": "boolean"},
          "source": {"type": "string"},
          "createdAt": {"type": "string"}
        }
      }
    },
    "history": {
      "type": "array",
      "description": "Command history records (`model.CommandHistoryRecord`). Optional keys (`alias`, `args`, `flags`, `finishedAt`, `summary`, `createdAt`) follow `omitempty` and may be absent.",
      "items": {
        "type": "object",
        "required": ["id", "command", "startedAt", "durationMs", "exitCode", "repoCount"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "integer"},
          "command": {"type": "string"},
          "alias": {"type": "string"},
          "args": {"type": "string"},
          "flags": {"type": "string"},
          "startedAt": {"type": "string"},
          "finishedAt": {"type": "string"},
          "durationMs": {"type": "integer"},
          "exitCode": {"type": "integer"},
          "summary": {"type": "string"},
          "repoCount": {"type": "integer"},
          "createdAt": {"type": "string"}
        }
      }
    },
    "bookmarks": {
      "type": "array",
      "description": "Bookmark records (`model.BookmarkRecord`). Optional keys (`args`, `flags`, `createdAt`) follow `omitempty` and may be absent.",
      "items": {
        "type": "object",
        "required": ["id", "name", "command"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "integer"},
          "name": {"type": "string"},
          "command": {"type": "string"},
          "args": {"type": "string"},
          "flags": {"type": "string"},
          "createdAt": {"type": "string"}
        }
      }
    }
  }
}
