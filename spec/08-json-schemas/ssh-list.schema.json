{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SSHList",
  "description": "Array of stored SSH keys emitted by `gitmap ssh list --json`",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "name",
      "privatePath",
      "fingerprint",
      "createdAt"
    ],
    "properties": {
      "id": {
        "type": "integer",
        "description": "SQLite row ID"
      },
      "name": {
        "type": "string",
        "description": "User-defined key name"
      },
      "privatePath": {
        "type": "string",
        "description": "Absolute path to the private key file"
      },
      "publicKey": {
        "type": "string",
        "description": "The public key content"
      },
      "fingerprint": {
        "type": "string",
        "description": "SSH key fingerprint"
      },
      "email": {
        "type": "string",
        "description": "Email associated with the key"
      },
      "createdAt": {
        "type": "string",
        "description": "ISO-8601 timestamp of when the key was created"
      }
    }
  }
}
